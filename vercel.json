{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "static/**",
          "Assets/**",
          "templates/**",
          "database/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/Assets/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "dest": "/api/index.py"
    },
    {
      "src": "/static/(.*)",
      "headers": { "Cache-Control": "public, max-age=86400" },
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ]
}

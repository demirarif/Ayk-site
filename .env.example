# KYA Hukuk Danışmanlık — Ortam Değişkenleri
# Bu dosyayı kopyalayın: cp .env.example .env
# .env dosyası Git'e commit edilmez!

# ─── Zorunlu ────────────────────────────────────────────────────────
# Flask güvenlik anahtarı — güçlü rastgele bir değer girin
# Üretmek için: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=BURAYA-GUCLU-BIR-SECRET-KEY-GIRIN

# ─── Veritabanı ──────────────────────────────────────────────────────
# Vercel / Neon PostgreSQL bağlantı dizesi (üretim)
# Neon'dan alınan URL: postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
# Supabase'den alınan URL: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ─── Admin Paneli ─────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=kya2024admin!

# ─── Cloudinary (Vercel'de dosya yüklemek için) ───────────────────────
# Ücretsiz hesap: https://cloudinary.com
# Değer biçimi: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=cloudinary://XXXXXXXXXXXXXXX:YYYYYYYYYYY@CLOUD_NAME

# ─── Ortam ───────────────────────────────────────────────────────────
FLASK_ENV=production
